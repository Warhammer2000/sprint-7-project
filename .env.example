# ─────────────────────────────────────────────────────────────
# Конфигурация RAG-бота. Скопируйте в .env и при желании заполните.
# Бот полностью работает и БЕЗ заполнения (офлайн-режим по умолчанию).
# ─────────────────────────────────────────────────────────────

# ── LLM backend ──────────────────────────────────────────────
# offline | openai | ollama
LLM_BACKEND=offline

# OpenAI (нужно, только если LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Можно указать совместимый endpoint (прокси / Azure / локальный llama.cpp server)
OPENAI_BASE_URL=

# Ollama (нужно, только если LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Embeddings backend ───────────────────────────────────────
# st  = sentence-transformers (качество, нужен torch)
# tfidf = лёгкий офлайн-вариант (sklearn), без скачивания моделей
EMBEDDINGS_BACKEND=st
ST_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── Retrieval ────────────────────────────────────────────────
TOP_K=5                      # сколько чанков уходит в контекст LLM
RECALL_K=20                  # широкий черновик ANN-поиска
MIN_SCORE=0.25               # порог косинусной близости для "Я не знаю"
CHUNK_SIZE=600               # символов в чанке
CHUNK_OVERLAP=120            # перекрытие чанков

# ── Prompting ────────────────────────────────────────────────
USE_FEW_SHOT=true
USE_COT=true                 # Chain-of-Thought (рассуждение скрыто от пользователя)

# ── Security ─────────────────────────────────────────────────
SECURITY_ENABLED=true        # слои защиты от prompt-injection (Задание 5)

# ── Paths ────────────────────────────────────────────────────
KB_DIR=knowledge_base
INDEX_DIR=index
LOG_DIR=logs

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Telegram (опционально, тариф Про) ────────────────────────
TELEGRAM_BOT_TOKEN=
